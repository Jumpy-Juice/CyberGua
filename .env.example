# 火山方舟 OpenAI 兼容接口（开发环境）
# 复制本文件为 .env.local 后填写；勿把含密钥的文件提交仓库。
#
# 密钥仅用于 Vite 开发代理（见 vite.config.ts），不会打进前端包。
ARK_API_KEY=

# 控制台「在线推理」创建的接入点 ID，例如 ep-xxxxxxxx
VITE_ARK_MODEL=

# 可选。默认 /api/ark/chat/completions
# VITE_ARK_CHAT_PATH=/api/ark/chat/completions

# 生产部署（如 Vercel）说明：
# - ARK_API_KEY：配置在平台环境变量（供 /api/ark/chat/completions 服务端函数读取）
# - VITE_ARK_MODEL：同样配置在平台环境变量（前端构建时注入模型 ID）
# - 可选 ARK_CHAT_URL：默认 https://ark.cn-beijing.volces.com/api/v3/chat/completions
#
# Netlify 说明（无 GitHub 也可）：
# - 已提供 netlify/functions/ark-chat-completions.mjs 与 netlify.toml
# - 在 Netlify 后台或 netlify CLI 中配置 ARK_API_KEY 与 VITE_ARK_MODEL
